class Solution(object):
    def maxArea(self, height):
        """
        :type height: List[int]
        :rtype: int
        """
        w=0
        l=0
        r=len(height)-1
        while l<r:
            v=(r-l)*(min(height[l], height[r]))
            if v>w:
                w=v
            if height[l]<height[r]:
                l+=1
            else:
                r-=1
        return w