class Solution(object):
    def isValid(self, s):
        stack = []

        for ch in s:
            if ch == '(' or ch == '[' or ch == '{':
                stack.append(ch)

            elif ch == ')':
                if len(stack) == 0 or stack.pop() != '(':
                    return False

            elif ch == ']':
                if len(stack) == 0 or stack.pop() != '[':
                    return False

            elif ch == '}':
                if len(stack) == 0 or stack.pop() != '{':
                    return False

        return len(stack) == 0